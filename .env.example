# mix-ingest configuration. Copy to .env next to the code (e.g. /opt/mix/.env)
# and fill in. Loaded once at process start by mixingest.config.load_config().
# In Docker, set these as container environment variables instead.

# Where finished mixes are filed (point a Navidrome library here).
LIBRARY_ROOT=/data/media/mixes

# Scratch space for in-progress downloads. Keep it on the same filesystem as
# LIBRARY_ROOT (moves stay atomic) and off a small root disk.
WORK_DIR=/data/inbox/.mixtmp

# Navidrome / Subsonic API. Used to trigger a rescan after filing. Optional —
# leave blank to skip the rescan step.
NAVIDROME_URL=http://navidrome:4533
NAVIDROME_USER=
NAVIDROME_PASS=

# UID/GID that filed output should be owned by (your media user).
# Unraid: typically 99/100 (nobody/users). Only effective when the service
# runs with enough privilege to chown (root, or already that user).
OWNER_UID=1000
OWNER_GID=1000

# Optional — SoundCloud Go+ OAuth token for 256 kbps AAC instead of 128 kbps.
# Grab from a browser request's "Authorization: OAuth <token>" header.
SOUNDCLOUD_OAUTH=

# Optional — path to a Netscape cookies.txt that gets YouTube past its "confirm you're
# not a bot" wall (datacenter IPs hit it on most content). Export from a browser signed
# into a THROWAWAY YouTube account (use a private window, export, then close it so the
# cookies aren't rotated/invalidated). Keep the file readable by the service user.
YOUTUBE_COOKIES=

# Optional — FlareSolverr endpoint; alternative to the built-in headful-Chromium
# fetcher for 1001tracklists (Cloudflare-walled).
FLARESOLVERR_URL=

# Optional — if set, POST /ingest requires header  X-Ingest-Secret: <value>
INGEST_SHARED_SECRET=

# Optional — host:port the FastAPI app binds to (put a reverse proxy in front for HTTPS).
BIND_HOST=0.0.0.0
BIND_PORT=8080

# Optional — User-Agent for MixesDB API lookups (be honest; include a contact URL).
MIXESDB_USER_AGENT=
